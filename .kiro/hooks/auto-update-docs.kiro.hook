{
  "enabled": true,
  "name": "Auto Update Docs on Source Change",
  "description": "Watches Python source files and relevant config files for changes, then asks the agent to update documentation in README.md or the docs/ folder to reflect the changes.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "*.py",
      "*.yaml",
      "*.yml",
      "*.toml",
      "*.cfg",
      "*.ini",
      "*.json"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A source file was just edited. Review the change and determine if any documentation needs to be updated. If so, update the relevant docs in README.md or the docs/ folder to keep them in sync with the code. Focus on meaningful changes like new features, API changes, architecture changes, or configuration changes. Skip trivial edits like formatting or minor refactors. Keep doc updates concise and minimal."
  }
}